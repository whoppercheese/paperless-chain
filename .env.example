# Paperless-ngx (external)
PAPERLESS_URL=http://host.docker.internal:8000
PAPERLESS_API_TOKEN=your_paperless_api_token

# Ollama (external)
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_LLM_MODEL=qwen3
OLLAMA_EMBED_MODEL=bge-m3
OLLAMA_CHAT_TIMEOUT=600
OLLAMA_EMBED_TIMEOUT=300

# Qdrant (included in docker-compose)
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=paperless-chain-documents
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# Windmill
WINDMILL_PORT=8000
WINDMILL_BASE_URL=http://localhost:8000
WINDMILL_WORKER_REPLICAS=1
WM_IMAGE=ghcr.io/windmill-labs/windmill:main

# Windmill CLI (./wmill-sync.sh)
WMILL_BASE_URL=http://localhost:8000
WMILL_WORKSPACE=paperless-chain
WMILL_TOKEN=your_windmill_api_token

# PostgreSQL (Windmill internal)
POSTGRES_USER=windmill
POSTGRES_PASSWORD=windmill
POSTGRES_DB=windmill
DATABASE_URL=postgres://windmill:windmill@windmill-db:5432/windmill

# Search UI
SEARCH_PORT=8888

# Notifications: log | matrix | hermes
NOTIFY_MODE=log

# Hermes webhook (optional, NOTIFY_MODE=hermes)
# URL format: http://<hermes-host>:8644/webhooks/<route-name>
HERMES_WEBHOOK_URL=http://host.docker.internal:8644/webhooks/paperless-chain
HERMES_WEBHOOK_SECRET=secret-from-hermes-webhook-subscribe

# Direct Matrix API (optional, NOTIFY_MODE=matrix)
MATRIX_HOMESERVER=https://matrix.example.org
MATRIX_ACCESS_TOKEN=your_matrix_access_token
MATRIX_ROOM_ID=!roomid:example.org
